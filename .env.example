# ══════════════════════════════════════════════════════════════════════════════
#  FileConverter Bot — Environment Variables
#  Copy this file to .env and fill in the values before running.
# ══════════════════════════════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────────────────────────────
# Get your token from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — no extra setup needed)
DATABASE_URL=sqlite+aiosqlite:///./bot.db

# PostgreSQL (uncomment and fill for production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/botdb

# ── File limits ───────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=20

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Max requests per user within the window
RATE_LIMIT_REQUESTS=5
RATE_LIMIT_WINDOW_SECONDS=60

# ── Temp file cleanup ─────────────────────────────────────────────────────────
# Delete temp files older than this many seconds (default: 1 hour)
TEMP_FILE_TTL_SECONDS=3600

# ── Paths (relative to project root) ─────────────────────────────────────────
TEMP_DIR=./temp
LOG_DIR=./logs

# ── Logging ───────────────────────────────────────────────────────────────────
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
